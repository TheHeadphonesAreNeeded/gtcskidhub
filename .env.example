# ============================================================
# SkidHub — Environment variable template
# ============================================================
# Copy this file to `.env.local` for local development, and add the
# same variables in the Netlify dashboard for production:
#   Site settings > Environment variables
#
# NEVER commit a real .env file. Only this template is tracked in git.

# --- Public site URL -----------------------------------------
# The canonical URL of your deployed site (no trailing slash).
# Locally this is http://localhost:8888 when running `netlify dev`.
SITE_URL=https://your-site.netlify.app

# --- Discord OAuth2 ------------------------------------------
# Create an application at https://discord.com/developers/applications
# Add a redirect: <SITE_URL>/.netlify/functions/auth-callback
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://your-site.netlify.app/.netlify/functions/auth-callback

# Discord user IDs (comma-separated) that are automatically granted the
# OWNER role on first login. Everyone else starts as USER.
OWNER_DISCORD_IDS=000000000000000000

# --- Supabase ------------------------------------------------
# Create a project at https://supabase.com and run supabase/schema.sql
SUPABASE_URL=https://your-project.supabase.co
# Service-role key is used ONLY inside Netlify Functions (server side).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Anon key is safe to expose to the browser (currently unused by the UI,
# reserved for optional client-side reads).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Session security ----------------------------------------
# A long random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_secret

# --- Google AdSense (optional) -------------------------------
# Leave blank until your AdSense account is approved. When set, the ad
# library loads sitewide and ad units render. Both values are public.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000
# A single ad-unit slot id used for the sponsored slot on the projects page.
NEXT_PUBLIC_ADSENSE_SLOT=0000000000

# --- Google Analytics (optional) -----------------------------
# Your GA4 Measurement ID from Google Analytics > Admin > Data Streams.
# Leave blank to disable analytics. This value is public.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
